# --- Supabase (persistance des réservations) -------------------------------
# Sans ces variables, un store en mémoire est utilisé (mode démo).
# Créez la table avec supabase/schema.sql (SQL Editor du dashboard Supabase).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Resend (envoi des e-mails de confirmation) -----------------------------
# Sans RESEND_API_KEY, les envois sont simulés (logués en console).
RESEND_API_KEY=re_xxxxxxxxxxxx
# Expéditeur : un domaine vérifié chez Resend en production.
EMAIL_FROM="ProClean Auto & Textil <contact@votre-domaine.fr>"
# Destinataire des notifications de nouvelle réservation.
FOUNDER_EMAIL=procleanauto01@gmail.com
